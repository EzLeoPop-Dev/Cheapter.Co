generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url - configured via prisma.config.ts for CLI and @prisma/adapter-pg for runtime
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum UserStatus {
  Active
  Banned
}

enum BookType {
  Hardcover
  EBook
  Manga
  Pack
}

enum StockStatus {
  InStock
  LowStock
  OutOfStock
}

enum DiscountType {
  percent
  fixed
  freeship
}

enum PromotionStatus {
  Active
  Expired
  Disabled
}

enum OrderStatus {
  PENDING      // รอชำระเงิน
  VERIFYING    // ตรวจสอบชำระเงิน
  PREPARING    // เตรียมการจัดส่ง
  SHIPPING     // อยู่ระหว่างการจัดส่ง
  COMPLETED    // สำเร็จ
  CANCELLED    // ถูกยกเลิก
  REFUNDED     // คืนเงินและคืนสินค้า
}

enum PaymentMethod {
  promptpay
  credit_card
  bank_transfer
  cod
}

enum ShippingMethod {
  standard
  express
  digital
}

enum TicketStatus {
  OPEN      // เปิด
  PENDING   // รอดำเนินการ
  CLOSED    // ปิดแล้ว
}

// ─────────────────────────────────────────────
//  USER & AUTH & ADDRESS
// ─────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String     // แนะนำใช้ bcrypt/argon2 สำหรับการย้ายจาก btoa
  role         UserRole   @default(CUSTOMER)
  status       UserStatus @default(Active)
  phone        String?
  birthdate    DateTime?
  
  profileImage String?    @db.Text    

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  addresses     Address[]
  orders        Order[]
  tickets       Ticket[]
  chatSessions  ChatSession[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  reviews       Review[]
  ebookProgress EbookProgress[]
  library       UserLibrary[]   // คลังหนังสือส่วนตัว (E-book ที่ซื้อแล้ว)
  userCoupons   UserCoupon[]    // คูปองที่ผู้ใช้เก็บไว้

  @@index([email])
  @@index([role])
  @@map("users")
}

model Address {
  id            Int      @id @default(autoincrement())
  label         String   // เช่น 'บ้าน', 'ที่ทำงาน'
  name          String
  phone         String
  streetAddress String
  city          String
  zipCode       String
  isDefault     Boolean  @default(false)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId]) // เพิ่ม index ให้ค้นหาที่อยู่ของ user ได้ไวขึ้น
  @@map("addresses")
}

// ─────────────────────────────────────────────
//  CATALOG — Books, Categories, Publishers
// ─────────────────────────────────────────────

model Publisher {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]

  @@map("publishers")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books Book[]

  @@map("categories")
}

model Book {
  id          Int         @id @default(autoincrement())
  title       String
  author      String
  description String?     @db.Text
  isbn        String?
  pages       Int?
  publishDate String?     
  bookType    BookType    @default(Hardcover)
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  stockStatus StockStatus @default(InStock)
  image       String?     
  rating      Decimal?    @db.Decimal(3, 1)
  reviewCount Int         @default(0) 
  sampleData  Json?       // { type: "pdf"/"epub", chapters: [...] } สำหรับอ่านตัวอย่างก่อนซื้อ
  ebookFile   String?     @db.Text // เก็บ URL ของไฟล์ E-book ตัวเต็ม
  sampleLimit Int?        // จำนวนหน้าที่ให้ทดลองอ่านได้ฟรี (สำหรับ PDF/EPUB)

  publisherId Int?
  categoryId  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  publisher     Publisher?      @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  ebookProgress EbookProgress[]
  libraryOwners UserLibrary[]   // เชื่อมโยงกับผู้ที่เป็นเจ้าของ E-book เล่มนี้
  packItems       BookPackItem[] @relation("PackToItems")
  includedInPacks BookPackItem[] @relation("ItemToPack")
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  episodes           BookEpisode[]

  @@index([bookType])
  @@index([categoryId])
  @@index([publisherId])
  @@index([stockStatus])
  @@map("books")
}

model BookEpisode {
  id          Int      @id @default(autoincrement())
  bookId      Int
  title       String
  content     String?  @db.Text
  orderIndex  Int      @default(0)
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_episodes")
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int 
  comment   String   @db.Text
  status    String   @default("visible")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String?  
  bookId  Int
  orderId String?

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  book  Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([bookId])
  @@index([userId])
  @@index([orderId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
//  PROMOTIONS / COUPONS
// ─────────────────────────────────────────────

model Promotion {
  id           Int             @id @default(autoincrement())
  name         String
  code         String          @unique 
  discountType DiscountType
  value        Decimal         @db.Decimal(10, 2) 
  status       PromotionStatus @default(Active)
  
  // ฟิลด์เพิ่มเติมเพื่อความสมบูรณ์ของระบบโปรโมชั่น
  minPurchase  Decimal         @db.Decimal(10, 2) @default(0) // ยอดซื้อขั้นต่ำ
  usageLimit   Int?            // จำกัดสิทธิ์การใช้รวม (null = ไม่จำกัด)
  usedCount    Int             @default(0)                    // จำนวนครั้งที่ถูกใช้ไปแล้ว
  endDate      DateTime?       

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderCoupons OrderCoupon[]
  userCoupons  UserCoupon[]

  @@index([code])
  @@index([status])
  @@map("promotions")
}

model UserCoupon {
  id          Int       @id @default(autoincrement())
  userId      String
  promotionId Int
  isUsed      Boolean   @default(false)
  collectedAt DateTime  @default(now())
  usedAt      DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([userId, promotionId])
  @@index([userId])
  @@index([promotionId])
  @@map("user_coupons")
}

// ─────────────────────────────────────────────
//  CART & WISHLIST
// ─────────────────────────────────────────────

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String   
  bookId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("cart_items")
}

model WishlistItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId String   
  bookId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────
//  ORDERS & PAYMENTS
// ─────────────────────────────────────────────

model Order {
  id              String         @id @default(cuid()) 
  status          OrderStatus    @default(PENDING)
  shippingMethod  ShippingMethod @default(standard)
  paymentMethod   PaymentMethod  @default(promptpay)

  recipientName   String
  recipientPhone  String?
  shippingAddress String         @db.Text

  subtotal        Decimal        @db.Decimal(10, 2)
  shippingFee     Decimal        @db.Decimal(10, 2) @default(0)
  discountAmount  Decimal        @db.Decimal(10, 2) @default(0)
  taxAmount       Decimal        @db.Decimal(10, 2) @default(0)
  totalAmount     Decimal        @db.Decimal(10, 2)

  slipUrl         String?        
  paymentTime     DateTime?      
  trackingNumber  String?        

  userId          String?        

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  coupons         OrderCoupon[]
  tickets         Ticket[]
  reviews         Review[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2) 
  bookTitle String  
  bookImage String? 
  bookType  BookType 

  orderId String
  bookId  Int?   

  order Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book?  @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([bookId])
  @@map("order_items")
}

model OrderCoupon {
  id          Int      @id @default(autoincrement())
  couponCode  String  
  discountAmt Decimal  @db.Decimal(10, 2)

  orderId     String
  promotionId Int?   

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_coupons")
}

// ─────────────────────────────────────────────
//  E-BOOK LIBRARY & READING PROGRESS
// ─────────────────────────────────────────────

/// คลังหนังสือ E-book ส่วนตัวของลูกค้า (สิทธิ์การเข้าถึงหนังสือที่ซื้อแล้ว)
model UserLibrary {
  id        Int      @id @default(autoincrement())
  purchaseAt DateTime @default(now())

  userId    String
  bookId    Int

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("user_libraries")
}

/// ความคืบหน้าการอ่าน E-Book
model EbookProgress {
  id              Int      @id @default(autoincrement())
  progressPercent Int      @default(0) // 0–100
  currentChapter  Int?
  lastReadAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String   
  bookId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@map("ebook_progress")
}

// ─────────────────────────────────────────────
//  SUPPORT TICKETS (ฝ่ายบริการลูกค้า)
// ─────────────────────────────────────────────

model Ticket {
  id        String       @id // "TK-1234"
  subject   String
  message   String       @db.Text
  status    TicketStatus @default(OPEN)

  customerName String?

  adminNote  String?   @db.Text
  resolvedAt DateTime?

  userId  String?  
  orderId String?  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

// ─────────────────────────────────────────────
//  LIVE CHAT (ระบบแชทแบบเรียลไทม์)
// ─────────────────────────────────────────────

model ChatSession {
  id        String       @id // "CHAT-1234"
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  messages  ChatMessage[]

  @@index([userId])
  @@index([status])
  @@map("chat_sessions")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  sessionId  String
  senderId   String?  // null if guest
  senderRole String   // "CUSTOMER", "ADMIN", "STAFF"
  message    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────
//  BOOK PACKS
// ─────────────────────────────────────────────

model BookPackItem {
  id       Int  @id @default(autoincrement())
  quantity Int  @default(1)
  
  packId   Int
  bookId   Int

  pack     Book @relation("PackToItems", fields: [packId], references: [id], onDelete: Cascade)
  book     Book @relation("ItemToPack", fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([packId, bookId])
  @@index([packId])
  @@index([bookId])
  @@map("book_pack_items")
}

// ─────────────────────────────────────────────
//  PURCHASE ORDERS & STOCK MOVEMENTS
// ─────────────────────────────────────────────

enum POStatus {
  Pending
  Partial
  Completed
  Cancelled
}

enum StockMovementType {
  IN
  OUT
  DAMAGED
  ADJUST
}

model PurchaseOrder {
  id           String   @id              // "PO-YYMM-NNN"
  supplier     String
  status       POStatus @default(Pending)
  expectedDate DateTime?
  createdBy    String
  note         String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PurchaseOrderItem[]

  @@index([status])
  @@index([createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              Int      @id @default(autoincrement())
  ordered         Int
  received        Int      @default(0)
  unitCost        Decimal  @db.Decimal(10, 2)

  purchaseOrderId String
  bookId          Int

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  book            Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([bookId])
  @@map("purchase_order_items")
}

model StockMovement {
  id          Int               @id @default(autoincrement())
  type        StockMovementType
  quantity    Int
  reference   String?           // e.g. "PO-2607-001"
  performedBy String
  note        String?           @db.Text
  balanceAfter Int              @default(0)

  bookId      Int
  book        Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())

  @@index([bookId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}